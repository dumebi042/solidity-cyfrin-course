					"contents": "{\n\n    function cleanup_t_uint160(value) -> cleaned {\n        cleaned := and(value, 0xffffffffffffffffffffffffffffffffffffffff)\n    }\n\n    function identity(value) -> ret {\n        ret := value\n    }\n\n    function convert_t_uint160_to_t_uint160(value) -> converted {\n        converted := cleanup_t_uint160(identity(cleanup_t_uint160(value)))\n    }\n\n    function convert_t_uint160_to_t_address(value) -> converted {\n        converted := convert_t_uint160_to_t_uint160(value)\n    }\n\n    function convert_t_contract$_Cows_$6_to_t_address(value) -> converted {\n        converted := convert_t_uint160_to_t_address(value)\n    }\n\n    function abi_encode_t_contract$_Cows_$6_to_t_address_fromStack(value, pos) {\n        mstore(pos, convert_t_contract$_Cows_$6_to_t_address(value))\n    }\n\n    function abi_encode_tuple_t_contract$_Cows_$6__to_t_address__fromStack_reversed(headStart , value0) -> tail {\n        tail := add(headStart, 32)\n\n        abi_encode_t_contract$_Cows_$6_to_t_address_fromStack(value0,  add(headStart, 0))\n\n    }\n\n    function convert_t_contract$_Birds_$11_to_t_address(value) -> converted {\n        converted := convert_t_uint160_to_t_address(value)\n    }\n\n    function abi_encode_t_contract$_Birds_$11_to_t_address_fromStack(value, pos) {\n        mstore(pos, convert_t_contract$_Birds_$11_to_t_address(value))\n    }\n\n    function abi_encode_tuple_t_contract$_Birds_$11__to_t_address__fromStack_reversed(headStart , value0) -> tail {\n        tail := add(headStart, 32)\n\n        abi_encode_t_contract$_Birds_$11_to_t_address_fromStack(value0,  add(headStart, 0))\n\n    }\n\n}\n",
